# ==============================================================================
# llm-interface-evaluation Environment Variables Configuration
# ==============================================================================
# This file defines all environment variables used by the llm-interface-evaluation gateway,
# workers, eval platform, and other infrastructure components.
# Copy this file to `.env` and fill in custom values.

# ------------------------------------------------------------------------------
# Gateway Settings
# ------------------------------------------------------------------------------
# Fastify gateway port
GATEWAY_PORT=3000

# Comma-separated list of valid API keys for authentication (required for /v1/inference)
API_KEYS=test-key-1,test-key-2

# ------------------------------------------------------------------------------
# Infrastructure URLs
# ------------------------------------------------------------------------------
# Redis connection URL (used by gateway, workers, and eval)
REDIS_URL=redis://localhost:6379

# PostgreSQL database connection URL (used by gateway, workers, and eval)
DATABASE_URL=postgresql://llmforge:password@localhost:5432/llmforge

# Embedding service base URL (python service endpoint)
EMBEDDING_SERVICE_URL=http://localhost:8000

# Ollama API base URL (local LLM backend)
OLLAMA_URL=http://localhost:11434

# ------------------------------------------------------------------------------
# Semantic Cache Configuration
# ------------------------------------------------------------------------------
# Cosine similarity threshold for considering a prompt a cache hit (0.0 to 1.0)
CACHE_SIM_THRESHOLD=0.92

# Cache entry Time To Live in seconds (default: 3600 seconds / 1 hour)
CACHE_TTL_SECONDS=3600

# Maximum number of entries allowed in the cache index before LRU eviction triggers
MAX_CACHE_ENTRIES=1000

# ------------------------------------------------------------------------------
# Queue & Worker Settings
# ------------------------------------------------------------------------------
# Maximum queue depth (jobs waiting + processing) before circuit breaker trips
MAX_QUEUE_DEPTH=500

# Concurrent jobs processed by each worker process
WORKER_CONCURRENCY=2

# Micro-batching window size in milliseconds (time to group incoming requests)
MICRO_BATCH_WINDOW_MS=50

# ------------------------------------------------------------------------------
# Circuit Breaker Configuration
# ------------------------------------------------------------------------------
# Error rate threshold (0.0 to 1.0) that trips the circuit breaker to OPEN
CB_ERROR_THRESHOLD=0.50

# Sliding window size in seconds for calculating error rates
CB_WINDOW_SECONDS=10

# Cooldown duration in seconds before moving from OPEN to HALF-OPEN state
CB_COOLDOWN_SECONDS=30

# ------------------------------------------------------------------------------
# Model Settings
# ------------------------------------------------------------------------------
# Default model to use if none is specified in the request
DEFAULT_MODEL=qwen2.5:3b

# Ordered fallback chain to use when the primary model's circuit breaker is OPEN
FALLBACK_MODEL_CHAIN=qwen2.5:3b,qwen2.5:1.5b

# ------------------------------------------------------------------------------
# Evaluation Settings
# ------------------------------------------------------------------------------
# Number of parallel scorer workers to run during evaluation
EVAL_PARALLEL_WORKERS=4

# Model to use as the LLM Judge for evaluation metrics (e.g., summarization rubrics)
EVAL_JUDGE_MODEL=qwen2.5:3b

# Maximum allowed drop in score compared to baseline before CI gate fails (0.0 to 1.0)
EVAL_REGRESSION_THRESHOLD=0.05
